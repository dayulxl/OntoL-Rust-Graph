# Ontology Server 配置模板
# 复制此文件为 .env 并修改对应值
#
# 本项目使用 Neo4j HTTP API (POST /db/neo4j/tx/commit)，非 Bolt 协议

# 服务端口
ONTOLOGY_PORT=8085

# Neo4j 连接（HTTP API）
# 本地: http://localhost:7474
# AuraDB: https://<instance-id>.databases.neo4j.io
ONTOLOGY_NEO4J_URI=http://localhost:7474
ONTOLOGY_NEO4J_USER=neo4j
ONTOLOGY_NEO4J_PASSWORD=your-password-here

# 默认推理策略: Exercise | WarFighting | Training
ONTOLOGY_MODE=Exercise

# 日志级别 (tracing/env_logger)
RUST_LOG=info
