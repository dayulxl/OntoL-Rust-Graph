# Ontology Server 配置模板
# 复制此文件为 .env 并修改对应值

# 服务端口
ONTOLOGY_PORT=8085

# ── 图数据库连接 ──
# Memgraph（内存图，Bolt 协议，默认端口 7687）:
#   ONTOLOGY_GRAPH_URI=memgraph://localhost:7687
#
# 认证（Memgraph 默认无认证，留空即可）:
#   ONTOLOGY_GRAPH_USER=
#   ONTOLOGY_GRAPH_PASSWORD=
ONTOLOGY_GRAPH_URI=memgraph://localhost:7687
ONTOLOGY_GRAPH_USER=
ONTOLOGY_GRAPH_PASSWORD=

# 默认推理策略: Balanced | Permissive | Strict
ONTOLOGY_MODE=Balanced

# 日志级别
RUST_LOG=info
